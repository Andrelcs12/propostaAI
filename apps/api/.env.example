NODE_ENV=development
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY_ID=
STRIPE_API_VERSION=2025-08-27.basil

# Opcao A: PostgreSQL local via Docker (padrao)
# 1. Abra o Docker Desktop e espere ficar "Running"
# 2. npm run db:up
# 3. npm run db:migrate
DATABASE_URL=postgresql://postgres:postgres@localhost:5438/proposta_ai
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5438/proposta_ai

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_SEARCH_ENABLED=true

FREE_PROPOSAL_LIMIT=3
PROPOSAL_PRICE_IN_CENTS=4900

# Segredo para renderizacao PDF (mesmo valor no web em PDF_RENDER_SECRET)
PDF_RENDER_SECRET=dev-render-secret
