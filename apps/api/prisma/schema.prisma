generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CompanyVisualPreference {
  LIGHT
  DARK
  SYSTEM
}

enum CompanyFontPreference {
  INTER
  MANROPE
  POPPINS
  DM_SANS
}

model User {
  id             String   @id @default(cuid())
  supabaseUserId String   @unique
  name           String
  email          String   @unique
  avatarUrl      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company Company?
}

model Company {
  id               String                  @id @default(cuid())
  userId           String                  @unique
  name             String
  tradeName        String?
  description      String?
  segment          String?
  website          String?
  commercialEmail  String?
  whatsapp         String?
  instagram        String?
  city             String?
  state            String?
  logoUrl          String?
  lightLogoUrl     String?
  primaryColor     String                  @default("#0F766E")
  secondaryColor   String                  @default("#14B8A6")
  accentColor      String                  @default("#06B6D4")
  visualPreference CompanyVisualPreference @default(LIGHT)
  fontPreference   CompanyFontPreference   @default(INTER)
  responsibleName  String?
  responsibleRole  String?
  document         String?
  address          String?
  presentationText String?
  footerText       String?
  contactText      String?
  onboardingStep   Int                     @default(1)
  onboardingDone   Boolean                 @default(false)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
